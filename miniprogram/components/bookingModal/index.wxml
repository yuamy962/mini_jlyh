<view class="booking-mask" wx:if="{{visible}}" bindtap="onMaskTap">
  <view class="booking-modal" catchtap="onModalTap">
    <view class="modal-header">
      <view class="modal-title">你的简历还有关键问题未修复</view>
      <view class="modal-subtitle">
        <text>当前简历很可能过不了筛选</text>
        <text>完整优化后可明显提升通过率</text>
      </view>
    </view>

    <view class="modal-body">
      <view class="status-section done">
        <view class="status-title">已完成</view>
        <view class="status-item">
          <view class="status-dot done-dot"></view>
          <text>基础优化（30%）</text>
        </view>
        <view class="status-item">
          <view class="status-dot done-dot"></view>
          <text>初步问题识别</text>
        </view>
      </view>

      <view class="status-section locked">
        <view class="status-title">未解锁</view>
        <view class="status-item">
          <view class="status-dot lock-dot"></view>
          <text>核心问题未修复</text>
        </view>
        <view class="status-item">
          <view class="status-dot lock-dot"></view>
          <text>面试通过率未提升</text>
        </view>
      </view>

      <view class="booking-info">
        <view class="info-title">当前为内测阶段</view>
        <view class="info-list">
          <view class="info-item">
            <view class="info-dot"></view>
            <text>完成预约后优先解锁完整优化功能</text>
          </view>
          <view class="info-item">
            <view class="info-dot"></view>
            <text>第一时间开放使用</text>
          </view>
          <view class="info-item">
            <view class="info-dot"></view>
            <text>可持续使用优化能力</text>
          </view>
        </view>
      </view>

      <view class="urgency-section">
        <text class="urgency-text">内测优惠即将结束（仅剩少量名额）</text>
      </view>

      <view class="social-proof">
        <text>已有 <text class="social-num">{{bookingCount}}</text> 人预约解锁完整版</text>
      </view>
    </view>

    <view class="modal-footer">
      <button class="btn-primary" bindtap="onBooking">
        <text>立即预约解锁</text>
      </button>
      <view class="btn-secondary" bindtap="onCancel">
        <text>再看看</text>
      </view>
    </view>

    <view class="close-btn" bindtap="onCancel">
      <text>关闭</text>
    </view>
  </view>
</view>
