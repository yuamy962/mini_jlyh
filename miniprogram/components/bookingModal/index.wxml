<view class="booking-mask" wx:if="{{visible}}" bindtap="onMaskTap">
  <view class="booking-modal" catchtap="onModalTap">
    <view class="modal-header">
      <view class="modal-title">你的简历还有致命问题未修复</view>
      <view class="modal-subtitle">
        <text>当前简历很可能过不了筛选</text>
        <text>完整优化后可明显提升通过率</text>
      </view>
    </view>

    <view class="modal-body">
      <view class="status-section done">
        <view class="status-title">已完成</view>
        <view class="status-item">
          <view class="status-dot done-dot"></view>
          <text>已优化前30%（基础优化）</text>
        </view>
        <view class="status-item">
          <view class="status-dot done-dot"></view>
          <text>已识别关键问题点</text>
        </view>
      </view>

      <view class="status-section locked">
        <view class="status-title">未解锁</view>
        <view class="status-item">
          <view class="status-dot lock-dot"></view>
          <text>核心问题未修复</text>
        </view>
        <view class="status-item">
          <view class="status-dot lock-dot"></view>
          <text>面试通过率未提升</text>
        </view>
      </view>

      <view class="price-section">
        <view class="price-label">正式版价格</view>
        <view class="price-row">
          <view class="price-item normal">
            <text class="price-name">单次</text>
            <text class="price-num">1.9元</text>
          </view>
          <view class="price-divider"></view>
          <view class="price-item recommend">
            <view class="rec-badge">推荐</view>
            <text class="price-name">全天</text>
            <text class="price-num">6.9元</text>
            <text class="rec-text">多数用户选择</text>
          </view>
        </view>
      </view>

      <view class="reward-section">
        <view class="reward-title">预约用户上线后可获得</view>
        <view class="reward-options">
          <text class="reward-item">免费解锁1次</text>
          <text class="reward-or">或</text>
          <text class="reward-item">专属5折优惠</text>
        </view>
      </view>

      <view class="urgency-section">
        <text class="urgency-text">内测优惠即将结束（仅剩少量名额）</text>
      </view>

      <view class="behavior-hint">
        <text>多数用户会优化2-3版简历，建议直接解锁全天使用</text>
      </view>

      <view class="social-proof">
        <text>已有 <text class="social-num">{{bookingCount}}</text> 人预约解锁完整版</text>
      </view>
    </view>

    <view class="modal-footer">
      <button class="btn-primary" bindtap="onBooking">
        <text>立即解锁完整优化</text>
      </button>
      <view class="btn-secondary" bindtap="onCancel">
        <text>再看看</text>
      </view>
    </view>

    <view class="close-btn" bindtap="onCancel">
      <text>关闭</text>
    </view>
  </view>
</view>
