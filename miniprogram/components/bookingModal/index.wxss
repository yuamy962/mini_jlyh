.booking-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.booking-modal {
  background: #fff;
  border-radius: 24rpx;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  position: relative;
  padding: 48rpx 32rpx 32rpx;
  box-sizing: border-box;
  animation: modalIn 0.3s ease;
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.modal-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.modal-subtitle {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.modal-subtitle text {
  font-size: 26rpx;
  color: #666;
}

.modal-body {
  margin-bottom: 32rpx;
}

.status-section {
  margin-bottom: 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
}

.status-section.done {
  background: #f0f9f4;
}

.status-section.locked {
  background: #fff5f5;
}

.status-title {
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #333;
}

.status-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 8rpx;
}

.status-icon {
  font-size: 28rpx;
}

.price-section {
  text-align: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.price-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.price-value {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.price-item {
  font-size: 28rpx;
  color: #333;
}

.price-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #e54545;
}

.price-divider {
  color: #ddd;
}

.reward-section {
  text-align: center;
  margin-bottom: 20rpx;
}

.reward-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.reward-options {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.reward-item {
  background: linear-gradient(135deg, #ffeaa7, #fdcb6e);
  color: #6c5ce7;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.reward-or {
  font-size: 24rpx;
  color: #999;
}

.urgency-section {
  text-align: center;
  margin-bottom: 16rpx;
}

.urgency-text {
  font-size: 26rpx;
  color: #e17055;
  font-weight: 600;
}

.social-proof {
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-primary {
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 46rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-primary::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-secondary {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 16rpx 0;
}

.close-btn {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
  font-size: 28rpx;
}
