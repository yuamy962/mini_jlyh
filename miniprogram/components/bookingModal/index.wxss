.booking-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.booking-modal {
  background: #fff;
  border-radius: 24rpx;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  position: relative;
  padding: 48rpx 32rpx 32rpx;
  box-sizing: border-box;
  animation: modalIn 0.3s ease;
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.modal-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.modal-subtitle {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.modal-subtitle text {
  font-size: 26rpx;
  color: #6b7280;
}

.modal-body {
  margin-bottom: 32rpx;
}

.status-section {
  margin-bottom: 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
}

.status-section.done {
  background: #f0fdf4;
}

.status-section.locked {
  background: #fef2f2;
}

.status-title {
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #374151;
}

.status-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #4b5563;
  margin-bottom: 8rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.done-dot {
  background: #22c55e;
}

.lock-dot {
  background: #ef4444;
}

.price-section {
  text-align: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.price-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.price-value {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.price-item {
  font-size: 28rpx;
  color: #374151;
}

.price-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #ef4444;
}

.price-divider {
  color: #e5e7eb;
}

.reward-section {
  text-align: center;
  margin-bottom: 20rpx;
}

.reward-title {
  font-size: 26rpx;
  color: #374151;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.reward-options {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.reward-item {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  color: #92400e;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.reward-or {
  font-size: 24rpx;
  color: #d1d5db;
}

.urgency-section {
  text-align: center;
  margin-bottom: 16rpx;
}

.urgency-text {
  font-size: 26rpx;
  color: #f97316;
  font-weight: 600;
}

.social-proof {
  text-align: center;
  font-size: 24rpx;
  color: #9ca3af;
}

.social-num {
  font-weight: 700;
  color: #2563eb;
}

.modal-footer {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-primary {
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 46rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.35);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  text-align: center;
  font-size: 28rpx;
  color: #d1d5db;
  padding: 16rpx 0;
}

.close-btn {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  font-size: 24rpx;
  color: #d1d5db;
  padding: 8rpx 16rpx;
}
