<view class="container">
  <!-- 顶部区域 -->
  <view class="header">
    <view class="main-title">让你的简历<text class="highlight">更容易拿到面试</text></view>
    <view class="sub-title">AI优化 · 问题诊断 · 匹配评分</view>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">
    <view class="form-item">
      <view class="label">目标岗位 <text class="required">*</text></view>
      <input 
        class="input" 
        placeholder="请输入目标岗位（如：前端开发工程师）" 
        value="{{jobTitle}}"
        bindinput="onJobTitleInput"
      />
    </view>

    <view class="form-item">
      <view class="label">简历内容 <text class="required">*</text></view>

      <!-- PDF上传区域 -->
      <view class="upload-section" bindtap="onUploadPdf">
        <view class="upload-box {{pdfUploading ? 'uploading' : ''}} {{pdfParsed ? 'parsed' : ''}}">
          <view class="upload-icon">📄</view>
          <view class="upload-text">
            <text wx:if="{{pdfUploading}}">{{pdfUploadStatus}}</text>
            <text wx:elif="{{pdfParsed}}">{{pdfFileName}} · 已识别 {{parsedPageCount}} 页 · {{contentLength}} 字</text>
            <text wx:else>上传PDF简历，自动识别内容</text>
          </view>
          <view class="upload-hint" wx:if="{{!pdfUploading && !pdfParsed}}">支持从微信聊天记录选择</view>
          <view class="upload-hint" wx:if="{{pdfParsed}}">点击可重新上传</view>
        </view>
      </view>

      <view class="textarea-wrap">
        <textarea 
          class="textarea" 
          placeholder="请粘贴你的简历内容（支持从Word/PDF复制）"
          value="{{resumeContent}}"
          bindinput="onResumeInput"
          maxlength="-1"
        />
        <view class="paste-btn" bindtap="onPaste">
          <text>一键粘贴</text>
        </view>
      </view>
      <view class="input-guide">建议包含：工作经历 / 项目经验 / 技能</view>
      <view class="word-count-row">
        <text class="privacy-tip">内容仅用于优化，不会存储或泄露</text>
        <text class="word-count {{wordCountStatus}}">{{contentLength}} 字 {{wordCountHint}}</text>
      </view>
    </view>

    <!-- 信任文案 -->
    <view class="trust-bar" wx:if="{{bookingCount > 0}}">
      <text class="trust-text">已有 <text class="trust-num">{{bookingCount}}</text> 人完成简历优化</text>
    </view>

    <button class="submit-btn {{canSubmit ? 'active' : ''}}" bindtap="onSubmit" disabled="{{!canSubmit || loading}}">
      {{loading ? 'AI优化中...' : '立即优化简历'}}
    </button>

    <view class="btn-hint">30秒生成优化结果</view>
  </view>

  <!-- 底部标签 -->
  <view class="footer-tags">
    <text>智能优化</text>
    <text class="tag-divider">|</text>
    <text>问题诊断</text>
    <text class="tag-divider">|</text>
    <text>匹配评分</text>
  </view>
</view>

<!-- 预约弹窗 -->
<booking-modal 
  visible="{{showBookingModal}}" 
  bookingCount="{{bookingCount}}"
  bind:close="onCloseBookingModal"
  bind:confirm="onBooking"
/>

<!-- 预约成功弹窗 -->
<booking-success-modal 
  visible="{{showSuccessModal}}"
  bind:close="onCloseSuccessModal"
/>
