page {
  background-color: #f5f6fa;
}

.container {
  padding: 48rpx 32rpx;
}

.header {
  margin-bottom: 56rpx;
}

.main-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.sub-title {
  font-size: 28rpx;
  color: #888;
}

.form-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.form-item {
  margin-bottom: 36rpx;
}

.label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.required {
  color: #e54545;
}

.input {
  height: 88rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.textarea {
  height: 400rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #aaa;
  margin-top: 8rpx;
}

.word-count.warning {
  color: #e54545;
}

.submit-btn {
  margin-top: 16rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: #d0d0d0;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.submit-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.submit-btn::after {
  border: none;
}

.features {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #666;
}

.admin-entry {
  margin-top: 48rpx;
  text-align: center;
  font-size: 26rpx;
  color: #aaa;
  padding: 24rpx;
}
