page {
  background-color: #f5f6fa;
}

.container {
  padding: 32rpx;
}

.score-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.score-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
}

.score-num {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.score-label {
  font-size: 26rpx;
  margin-top: 12rpx;
  opacity: 0.9;
}

.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

.content-box {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
}

.content-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
}

.problem-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.problem-item {
  background: #fff5f5;
  border-left: 6rpx solid #e54545;
  padding: 20rpx 24rpx;
  border-radius: 0 12rpx 12rpx 0;
}

.problem-type {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #e54545;
  margin-bottom: 8rpx;
}

.problem-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
