page {
  background-color: #f5f6fa;
}

.container {
  padding: 32rpx;
}

/* 评分区域 */
.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.score-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.3);
}

.score-num {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.score-label {
  font-size: 26rpx;
  margin-top: 12rpx;
  opacity: 0.9;
}

.score-comment {
  margin-top: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
}

.score-comment.low {
  color: #dc2626;
  background: #fef2f2;
}

.score-comment.mid {
  color: #ea580c;
  background: #fff7ed;
}

.score-comment.high {
  color: #16a34a;
  background: #f0fdf4;
}

/* 卡片通用 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.section-hint {
  font-size: 24rpx;
  color: #2563eb;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.count-badge {
  font-size: 22rpx;
  color: #9ca3af;
  font-weight: 400;
  background: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.content-box {
  background: #f9fafb;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}

.content-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.8;
}

/* 简历截断展示 */
.resume-box {
  position: relative;
  padding: 24rpx;
}

.resume-preview {
  max-height: 360rpx;
  overflow: hidden;
  position: relative;
}

.resume-preview::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to bottom, rgba(249,250,251,0), rgba(249,250,251,1));
}

.lock-overlay {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 8rpx;
  margin-top: -40rpx;
  z-index: 2;
}

.lock-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #fee2e2;
  color: #dc2626;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.lock-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #dc2626;
  margin-bottom: 8rpx;
}

.lock-desc {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 20rpx;
  text-align: center;
}

.unlock-btn {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 52rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

/* 问题列表 */
.problem-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.problem-item {
  background: #fff;
  border: 2rpx solid #fee2e2;
  border-left: 6rpx solid #dc2626;
  padding: 24rpx;
  border-radius: 0 16rpx 16rpx 0;
}

.problem-header {
  margin-bottom: 12rpx;
}

.problem-tag {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  color: #dc2626;
  background: #fef2f2;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.problem-desc {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
}

/* 查看更多问题 */
.more-problems {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #fef2f2;
  border-radius: 12rpx;
  border: 2rpx solid #fecaca;
  font-size: 26rpx;
  color: #dc2626;
  font-weight: 500;
}

.more-icon {
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 50%;
  background: #dc2626;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.more-arrow {
  font-size: 32rpx;
  color: #dc2626;
}
