page {
  background-color: #f5f6fa;
}

.container {
  padding: 32rpx;
}

/* 评分区域 */
.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.score-circle {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.3);
}

.score-num {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.score-label {
  font-size: 26rpx;
  margin-top: 12rpx;
  opacity: 0.9;
}

.score-comment {
  margin-top: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
}

.score-comment.low {
  color: #dc2626;
  background: #fef2f2;
}

.score-comment.mid {
  color: #ea580c;
  background: #fff7ed;
}

.score-comment.high {
  color: #16a34a;
  background: #f0fdf4;
}

/* 解锁后评分 */
.score-unlocked {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.score-main {
  font-size: 64rpx;
  font-weight: 800;
  color: #2563eb;
  line-height: 1;
}

.score-unlocked .score-label {
  font-size: 26rpx;
  color: #9ca3af;
  margin-top: 12rpx;
}

.score-status {
  margin-top: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

.score-status.good {
  color: #16a34a;
  background: #f0fdf4;
}

/* 卡片通用 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.comparison-section {
  background: linear-gradient(180deg, #fff 0%, #f8fafc 100%);
}

.summary-section {
  background: linear-gradient(135deg, #f0fdf4, #fff);
  border: 2rpx solid #bbf7d0;
}

.section-hint {
  font-size: 24rpx;
  color: #2563eb;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.count-badge {
  font-size: 22rpx;
  color: #9ca3af;
  font-weight: 400;
  background: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.content-box {
  background: #f9fafb;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
}

.content-text {
  font-size: 28rpx;
  color: #4b5563;
  line-height: 1.8;
}

/* ===== 优化前后对比模块 ===== */
.comparison-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #e5e7eb;
}

.comparison-card.preview {
  border: 2rpx solid #bfdbfe;
  background: linear-gradient(180deg, #eff6ff, #fff);
}

.comparison-card:last-child {
  margin-bottom: 0;
}

.compare-row {
  margin-bottom: 12rpx;
}

.compare-label {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.compare-before {
  font-size: 28rpx;
  color: #9ca3af;
  background: #f3f4f6;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  text-decoration: line-through;
}

.compare-arrow {
  text-align: center;
  font-size: 32rpx;
  color: #2563eb;
  font-weight: 700;
  margin: 8rpx 0;
}

.compare-after {
  font-size: 28rpx;
  color: #1f2937;
  background: #f0fdf4;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  line-height: 1.6;
  font-weight: 500;
}

.preview-after {
  max-height: 100rpx;
  overflow: hidden;
  position: relative;
}

.preview-after::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: linear-gradient(to bottom, rgba(240,253,244,0), rgba(240,253,244,1));
}

.after-normal {
  color: #1f2937;
}

.after-highlight {
  color: #dc2626;
  font-weight: 700;
}

.compare-explanation {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #e5e7eb;
  font-size: 24rpx;
}

.exp-label {
  color: #2563eb;
  font-weight: 600;
}

.exp-text {
  color: #6b7280;
}

/* 对比模块风险提示 */
.comparison-warning {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #fffbeb;
  border-radius: 10rpx;
  border: 2rpx solid #fcd34d;
}

.warning-dot {
  width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  border-radius: 50%;
  background: #f59e0b;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.warning-text {
  font-size: 24rpx;
  color: #92400e;
  line-height: 1.5;
}

/* 预览锁定提示 */
.preview-lock {
  text-align: center;
  padding: 32rpx 24rpx;
  background: #fef2f2;
  border-radius: 16rpx;
  border: 2rpx solid #fecaca;
}

.preview-lock-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #dc2626;
  margin-bottom: 8rpx;
}

.preview-lock-sub {
  font-size: 24rpx;
  color: #ef4444;
  margin-bottom: 12rpx;
}

.preview-hint {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 20rpx;
}

.unlock-btn-inline {
  display: inline-block;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

/* 简历截断展示 */
.resume-box {
  position: relative;
  padding: 24rpx;
}

.resume-preview {
  max-height: 360rpx;
  overflow: hidden;
  position: relative;
}

.resume-preview::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to bottom, rgba(249,250,251,0), rgba(249,250,251,1));
}

.resume-full {
  padding: 28rpx;
}

.lock-overlay {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 8rpx;
  margin-top: -40rpx;
  z-index: 2;
}

.lock-icon {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #fee2e2;
  color: #dc2626;
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.lock-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #dc2626;
  margin-bottom: 8rpx;
}

.lock-desc {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 20rpx;
  text-align: center;
}

.unlock-btn {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 52rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

/* 优化总结 */
.summary-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #374151;
}

.summary-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #22c55e;
  flex-shrink: 0;
}

/* 问题列表 */
.problem-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.problem-item {
  background: #fff;
  border: 2rpx solid #fee2e2;
  border-left: 6rpx solid #dc2626;
  padding: 24rpx;
  border-radius: 0 16rpx 16rpx 0;
}

.problem-header {
  margin-bottom: 12rpx;
}

.problem-tag {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  color: #dc2626;
  background: #fef2f2;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.problem-desc {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
}

/* 查看更多问题 */
.more-problems {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #fef2f2;
  border-radius: 12rpx;
  border: 2rpx solid #fecaca;
  font-size: 26rpx;
  color: #dc2626;
  font-weight: 500;
}

.more-icon {
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 50%;
  background: #dc2626;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.more-arrow {
  font-size: 32rpx;
  color: #dc2626;
}

/* 复制区域 */
.copy-section {
  margin-top: 32rpx;
  text-align: center;
}

.copy-btn {
  display: inline-block;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 20rpx 64rpx;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

.copy-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

/* 复用引导 */
.reuse-section {
  background: linear-gradient(135deg, #eff6ff, #fff);
  border: 2rpx solid #bfdbfe;
  text-align: center;
  padding: 40rpx 32rpx;
}

.reuse-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e40af;
  margin-bottom: 12rpx;
}

.reuse-desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 28rpx;
}

.reuse-btn {
  display: inline-block;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 56rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}
