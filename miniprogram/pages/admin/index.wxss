page {
  background-color: #f5f6fa;
}

.container {
  padding: 32rpx;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
}

.card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.stat-card.primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.stat-card.primary .stat-value {
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: #888;
}

.stat-card.primary .stat-label {
  color: rgba(255,255,255,0.8);
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.rate-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.rate-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rate-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.rate-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.rate-desc {
  font-size: 22rpx;
  color: #999;
}

.rate-value {
  font-size: 36rpx;
  font-weight: 700;
}

.rate-value.good { color: #00b894; }
.rate-value.normal { color: #fdcb6e; }
.rate-value.bad { color: #e54545; }

.dist-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dist-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dist-name {
  font-size: 26rpx;
  color: #555;
  width: 160rpx;
  flex-shrink: 0;
}

.dist-bar-wrap {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.dist-bar {
  height: 100%;
  background: #b2bec3;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.dist-bar.clicked {
  background: #fdcb6e;
}

.dist-bar.booked {
  background: #00b894;
}

.dist-num {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

.standard-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.standard-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: #555;
}

.standard-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.standard-item.good .standard-dot { background: #00b894; }
.standard-item.normal .standard-dot { background: #fdcb6e; }
.standard-item.bad .standard-dot { background: #e54545; }

.refresh-btn {
  margin-top: 16rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.refresh-btn::after {
  border: none;
}
